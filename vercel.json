{
    "version": 2,
    "functions": {
        "api/*.js": {
            "memory": 256,
            "maxDuration": 30
        }
    },
    "builds": [
        {
            "src": "api/fetch-anime.js",
            "use": "@vercel/node"
        },
        {
            "src": "api/preview.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}